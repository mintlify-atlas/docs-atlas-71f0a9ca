  "publicApiSurface": [
    "ConfigCache - Global configuration cache with TTL support",
    "loadAgentConfig(agentId) - Load agent configuration",
    "ElicitationEngine - Interactive prompting system",
    "SessionManager - Session context management",
    "CodeIntelClient - Code intelligence and analysis",
    "QualityGateRunner - Execute quality gates",
    "TaskExecutor - Execute workflow tasks",
    "HookRuntime - Lifecycle hook management",
    "aiox install - Install framework in project",
    "aiox init <name> - Create new project",
    "aiox validate - Validate installation",
    "aiox update - Update to latest version",
    "aiox config - Manage configuration",
    "Agent commands: *help, *create, *develop, *test, *deploy",
